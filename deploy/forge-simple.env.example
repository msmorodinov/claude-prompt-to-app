# Cloudflare R2 storage credentials for forge-simple (carousel app artifacts)
# Copy this file to /etc/forge-simple.env on the VPS and chmod 0600.
# Do NOT commit the real credentials — this is a template only.

R2_ENDPOINT_URL=https://58614ccc597b104444c430b0546b3c31.r2.cloudflarestorage.com
R2_BUCKET=prompt2app
R2_ACCESS_KEY_ID=<replace-with-scoped-token-key>
R2_SECRET_ACCESS_KEY=<replace-with-scoped-token-secret>
R2_REGION=auto
R2_KEY_PREFIX=prod/
R2_PRESIGNED_URL_TTL=300

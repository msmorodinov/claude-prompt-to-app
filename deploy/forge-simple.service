[Unit]
Description=Forge Simple backend (prompt2app)
After=network.target

[Service]
EnvironmentFile=/etc/forge-simple.env
WorkingDirectory=/opt/forge-simple
ExecStart=/opt/forge-simple/.venv/bin/python -m backend.server
Restart=always
RestartSec=5

# Filesystem isolation
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes

# Writable paths: SQLite WAL files, deploy logs, playwright cache, claude CLI state, renderer workspace
ReadWritePaths=/opt/forge-simple/backend
ReadWritePaths=/opt/forge-simple/deploy/logs
ReadWritePaths=/root/.cache/ms-playwright
ReadWritePaths=/root/.claude
ReadWritePaths=/var/lib/forge-simple-render

# Privilege reduction
NoNewPrivileges=yes
RestrictSUIDSGID=yes
LockPersonality=yes

# Capability bounding: only what bwrap needs (SYS_ADMIN, SYS_CHROOT) + net bind
CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_SETUID CAP_SETGID CAP_SYS_ADMIN CAP_SYS_CHROOT
AmbientCapabilities=

# Kernel protection
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes

# Namespaces: allow user/pid/mount/ipc/uts/cgroup/net (required by bwrap)
# List-form — NOT RestrictNamespaces=yes (that would block bwrap clone())
RestrictNamespaces=cgroup ipc net mnt pid user uts

RestrictRealtime=yes

# Syscall filter: base service set + mount/clone for bwrap
# NOT MemoryDenyWriteExecute — Chromium V8 JIT requires W+X pages
# NOT PrivateNetwork — backend needs outbound HTTPS to R2
SystemCallFilter=@system-service @mount
SystemCallErrorNumber=EPERM

[Install]
WantedBy=multi-user.target
